# STK Backend - Environment Variables
# Copy file ini ke .env dan sesuaikan nilainya

# Application
APP_NAME=stk-backend
APP_PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stk_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_EXTERNAL_PORT=5433
DB_MAX_POOL=10

# pgAdmin (Docker only)
PGADMIN_PORT=8081

# CORS - pisahkan multiple origin dengan koma
CORS_ORIGIN=http://localhost:3001

# JWT
JWT_SECRET=ganti-dengan-secret-yang-kuat-di-production
JWT_EXPIRES_IN=86400

# Super Admin Seeder
SUPER_ADMIN_EMAIL=admin@stk.id
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_NAME=Super Administrator
SUPER_ADMIN_PHONE=081234567890

# Multipart / File Upload
MULTIPART_FILE_SIZE_LIMIT=10000000
MULTIPART_FILES_LIMIT=10
MULTIPART_FIELD_NAME_SIZE_LIMIT=100
MULTIPART_FIELD_SIZE_LIMIT=1000000
MULTIPART_FIELDS_LIMIT=100
